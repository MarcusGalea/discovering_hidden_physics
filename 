       bsub -r -H -N -Ne -i /tmp/input/jobfile.sh -outdir /tmp/output -C
       5 -c 2022:12:12 -cn_mem 256 -hostfile /tmp/myHostFile.txt -q nor‐
       mal -G myUserGroup -u "user@example.com" myjob

       The following YAML file specifies the equivalent job submission
       command:

       io:
           inputFile: /tmp/input/jobfile.sh
           outputDir: /tmp/output
       limit:
           coreLimit: 5
           cpuTimeLimit: 2022:12:12
       resource:
           computeNodeMem: 256
           hostFile: /tmp/myHostFile.txt
       properties:
           queueName: normal
           rerun: null
       schedule:
           hold: ""
           userGroup: myUserGroup
       notify:
           notifyJobDone: ""
           notifyJobExit:
           mailUser: user@example.com
       command: myjob

